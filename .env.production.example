APP_NAME="BS Estetic"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.bs-estetic.com
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
APP_MAINTENANCE_DRIVER=file

# ── Base de Datos MySQL (crear en cPanel → MySQL Databases) ─────────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=PONER_NOMBRE_BD
DB_USERNAME=PONER_USUARIO_BD
DB_PASSWORD=PONER_PASSWORD_BD

# ── Cache y Sesiones ─────────────────────────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

# ── Seguridad de sesiones (cookies HTTPS-only) ───────────────────────────────
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_ENCRYPT=true

# ── Email (usar datos del hosting) ──────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mail.bs-estetic.com
MAIL_PORT=587
MAIL_USERNAME=info@bs-estetic.com
MAIL_PASSWORD=PONER_PASSWORD_EMAIL
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@bs-estetic.com
MAIL_FROM_NAME="BS Estetic"

# ── APIs opcionales ──────────────────────────────────────────────────────────
GROQ_API_KEY=
CALLMEBOT_API_KEY=
ADMIN_WHATSAPP_PHONE=

# ── Redes Sociales (configurar en /admin/redes-sociales/configurar) ──────────
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
